<Window x:Class="AdminFelület.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:AdminFelület"
        mc:Ignorable="d"
        Title="ReceptesAdmin" Height="600" Width="1000"
        WindowStartupLocation="CenterScreen"
        Loaded="Window_Loaded">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <Border Grid.Row="0" Background="#252526" Padding="15">
            <Grid>
                <StackPanel Orientation="Horizontal">
                    <TextBlock Text="Receptes Oldal - Admin Panel" FontSize="18" FontWeight="Bold" Foreground="White" VerticalAlignment="Center"/>
                </StackPanel>

                <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                    <ComboBox x:Name="ViewSelector" Width="150" Height="30">
                        <ComboBoxItem Content="Felhasználók" IsSelected="True"/>
                        <ComboBoxItem Content="Receptek"/>
                        <ComboBoxItem Content="Cimkék"/>
                        <ComboBoxItem Content="Kommentek"/>
                        <ComboBoxItem Content="Mentett receptek"/>
                        <ComboBoxItem Content="Like-ok"/>
                        <ComboBoxItem Content="Recept-Címke kapcsolatok"/>
                    </ComboBox>
                </StackPanel>
            </Grid>
        </Border>

        <Grid Grid.Row="1">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="3*"/>
                <ColumnDefinition/>
            </Grid.ColumnDefinitions>
            
            <StackPanel Grid.Column="1">
                <Button x:Name="RefreshButton" Content="Frissites" Click="RefreshButton_Click"></Button>
                <Button x:Name="EditButton" Content="Módosítás" IsEnabled="False" Click="EditButton_Click"/>
                <Button x:Name="DeleteButton" Content="Törlés" IsEnabled="False" Click="DeleteButton_Click"/>
                <StackPanel>
                    <TextBlock Text="Kiválasztott elem:"/>
                    <TextBlock x:Name="SelectedItemTextBlock" Text="Nincs kiválasztott elem." TextWrapping="Wrap"/>
                    <TextBlock></TextBlock>
                </StackPanel>
                <StackPanel>
                    <TextBlock Text="Statisztikák:" FontWeight="Bold" TextDecorations="Underline"/>
                    <TextBlock x:Name="StatsText" TextWrapping="Wrap"></TextBlock>
                </StackPanel>
            </StackPanel>
            <DataGrid x:Name="DataGrid" AutoGenerateColumns="False" IsReadOnly="False" SelectionMode="Single" SelectionChanged="DataGrid_SelectionChanged" Grid.RowSpan="2"/>
        </Grid>
    </Grid>
</Window>
