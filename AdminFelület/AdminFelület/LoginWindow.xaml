<Window x:Class="AdminFelület.LoginWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:AdminFelület"
        mc:Ignorable="d"
        Title="Admin bejelentkezés" Height="300" Width="400"
        WindowStartupLocation="CenterScreen"
        ResizeMode="NoResize">
    <Grid>
        <StackPanel VerticalAlignment="Center" Margin="50">
            <TextBlock TextWrapping="Wrap" Text="Felhasználónév:"/>
            <TextBox Name="UsernameBox" Margin="5,0,0,0" FontSize="14" Padding="5" Height="30"/>

            <TextBlock TextWrapping="Wrap" Text="Jelszó:" Margin="0,15,0,5"/>
            <PasswordBox Name="PasswordBox" FontSize="14" Padding="5" Height="30"/>

            <TextBlock x:Name="ErrorText" Text="" Foreground="Red" TextWrapping="Wrap" Visibility="Collapsed" Margin="0,10,0,0"/>

            <Button Content="Bejelentkezés" Margin="0,20,0,0" Height="30" FontSize="14" FontWeight="Bold" BorderThickness="0" Click="LoginButton_Click"/> 
        </StackPanel>

    </Grid>
</Window>
